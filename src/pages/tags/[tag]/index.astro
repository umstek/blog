---
import Layout from '@/layouts/Layout.astro';
import FeedCard from '@/components/FeedCard.astro';
import { getFeed } from '@/lib/feed';
import { getUniqueTags, getPostsByTag } from '@/lib/tags';

export async function getStaticPaths() {
  const feed = await getFeed();
  const tags = getUniqueTags(feed);
  return tags.map(({ tag }) => ({
    params: { tag },
    props: { tag, items: getPostsByTag(feed, tag) },
  }));
}

interface Props {
  tag: string;
  items: Awaited<ReturnType<typeof getFeed>>;
}

const { tag, items } = Astro.props;
---

<Layout title={`#${tag}`}>
  <section class="space-y-8">
    <header>
      <h1 class="text-3xl font-bold tracking-tight">#{tag}</h1>
      <p class="mt-2" style="color: var(--color-text-muted)">
        {items.length} {items.length === 1 ? 'item' : 'items'}
      </p>
    </header>
    <div class="space-y-8">
      {items.map((item) => <FeedCard item={item} />)}
    </div>
  </section>
</Layout>
