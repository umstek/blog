---
import Layout from '@/layouts/Layout.astro';
import PostCard from '@/components/PostCard.astro';
import { getPublishedPosts } from '@/lib/posts';
import { getUniqueTags, getPostsByTag } from '@/lib/tags';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const tags = getUniqueTags(posts);
  return tags.map(({ tag }) => ({
    params: { tag },
    props: { tag, posts: getPostsByTag(posts, tag) },
  }));
}

interface Props {
  tag: string;
  posts: Awaited<ReturnType<typeof getPublishedPosts>>;
}

const { tag, posts } = Astro.props;
---

<Layout title={`#${tag}`}>
  <section class="space-y-8">
    <header>
      <h1 class="text-3xl font-bold tracking-tight">#{tag}</h1>
      <p class="mt-2" style="color: var(--color-text-muted)">
        {posts.length} {posts.length === 1 ? 'post' : 'posts'}
      </p>
    </header>
    <div class="space-y-8">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </section>
</Layout>
