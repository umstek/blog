---
import Layout from '@/layouts/Layout.astro';
import { getFeed } from '@/lib/feed';
import { getUniqueTags } from '@/lib/tags';

const feed = await getFeed();
const tags = getUniqueTags(feed);
---

<Layout title="Tags">
  <section class="space-y-6">
    <h1 class="text-3xl font-bold tracking-tight">Tags</h1>
    <div class="flex flex-wrap gap-2">
      {tags.map(({ tag, count }) => (
        <a
          href={`/tags/${tag}`}
          class="rounded-full border border-border px-3 py-1 text-sm no-underline hover:bg-bg-subtle"
          style="color: var(--color-text-muted)"
        >
          #{tag} <span class="opacity-60">({count})</span>
        </a>
      ))}
    </div>
  </section>
</Layout>
