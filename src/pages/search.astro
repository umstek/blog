---
import Layout from '@/layouts/Layout.astro';
import '@pagefind/default-ui/css/ui.css';
---

<Layout title="Search">
  <section class="space-y-6">
    <h1 class="text-3xl font-bold tracking-tight">Search</h1>
    <!--
      Pagefind builds the index at build time (see the `pagefind --site dist`
      step in package.json). The UI is loaded from the @pagefind/default-ui
      npm package, not a runtime /pagefind/ path, so it resolves at build time.
    -->
    <div id="pagefind-search" class="pagefind-ui"></div>
    <p class="text-sm" style="color: var(--color-text-muted)">
      Search runs client-side against a build-time index — no server, no tracking.
    </p>
  </section>

  <script>
    import { PagefindUI } from '@pagefind/default-ui';

    function initSearch() {
      const el = document.querySelector<HTMLElement>('#pagefind-search');
      if (!el || el.querySelector('form')) return; // already initialized

      // In dev, the index doesn't exist until the first build — warn gracefully.
      if (import.meta.env.DEV) {
        el.innerHTML =
          '<p><strong>Dev mode:</strong> run <code>bun run build</code> once to generate the search index, then refresh.</p>';
        return;
      }

      new PagefindUI({
        element: '#pagefind-search',
        showSubResults: true,
        showImages: false,
      });
    }

    initSearch();
    document.addEventListener('astro:after-swap', initSearch);
  </script>

  <style is:global>
    /* Map Pagefind UI tokens to the site theme. */
    #pagefind-search {
      --pagefind-ui-font: var(--font-sans);
      --pagefind-ui-text: var(--color-text);
      --pagefind-ui-background: var(--color-bg);
      --pagefind-ui-border: var(--color-border);
      --pagefind-ui-primary: var(--color-accent);
      --pagefind-ui-tag: var(--color-bg-subtle);
      --pagefind-ui-border-radius: 0.375rem;
      --pagefind-ui-border-width: 1px;
    }
  </style>
</Layout>
