---
import { type CollectionEntry, render } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '@/layouts/Layout.astro';
import FormattedDate from '@/components/FormattedDate.astro';
import SeriesNav from '@/components/SeriesNav.astro';
import Comments from '@/components/Comments.astro';
import { getPublishedPosts, getReadingTime, getPostURL, getSlug } from '@/lib/posts';
import { getSeriesPosts } from '@/lib/series';
import { hasMath } from '@/lib/math';
import { SITE } from '@/config';
import { getImagePath } from 'astro-takumi';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({
    params: { slug: getSlug(post) },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await render(post);
const minutes = getReadingTime(post.body ?? '');

// Related posts: same tag, exclude self, take a handful.
const all = await getPublishedPosts();
const related = all
  .filter((p) => p.id !== post.id && p.data.tags.some((t) => post.data.tags.includes(t)))
  .slice(0, 3);

// Series: ordered siblings, if this post belongs to one.
const seriesPosts = getSeriesPosts(all, post);

const description = post.data.description;
// Only load KaTeX CSS when the post body actually contains math syntax.
const postHasMath = hasMath(post.body ?? '');

// Cover image: the glob loader resolves co-located images to ImageMetadata;
// string values (external/legacy) are rendered as plain <img>.
const cover = post.data.ogImage;
const coverIsAsset = cover != null && typeof cover !== 'string';

// BlogPosting structured data for rich results. astro-takumi generates an OG
// image at a predictable path per page; reference it here too.
const ogImageURL = new URL(
  getImagePath({ url: Astro.url, site: Astro.site ?? new URL(SITE.website), format: 'webp' }),
  Astro.site ?? SITE.website,
);
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description,
  datePublished: post.data.pubDatetime.toISOString(),
  ...(post.data.modDatetime && {
    dateModified: post.data.modDatetime.toISOString(),
  }),
  author: { '@type': 'Person', name: post.data.author },
  keywords: post.data.tags.join(', '),
  image: ogImageURL.href,
  mainEntityOfPage: { '@type': 'WebPage', '@id': Astro.url.href },
};
---

<Layout title={post.data.title} description={description} canonicalURL={post.data.canonicalURL} jsonLd={jsonLd} math={postHasMath}>
  <article class="space-y-10" data-pagefind-body>
    <header class="space-y-4">
      {coverIsAsset && (
        <Image
          src={cover}
          alt={`Cover for ${post.data.title}`}
          width={800}
          height={420}
          loading="eager"
          data-pagefind-ignore
          class="rounded-lg border border-border"
        />
      )}
      {cover && !coverIsAsset && (
        <img
          src={cover}
          alt={`Cover for ${post.data.title}`}
          class="rounded-lg border border-border"
        />
      )}
      <h1 class="text-4xl font-bold leading-tight tracking-tight md:text-5xl">{post.data.title}</h1>
      <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm" style="color: var(--color-text-muted)">
        <FormattedDate date={post.data.pubDatetime} />
        <span aria-hidden="true">·</span>
        <span>{minutes} min read</span>
        {post.data.modDatetime && (
          <>
            <span aria-hidden="true">·</span>
            <span>updated <FormattedDate date={post.data.modDatetime} /></span>
          </>
        )}
      </div>
      <div class="flex flex-wrap gap-2">
        {post.data.tags.map((tag) => (
          <a
            href={`/tags/${tag}`}
            class="rounded-full border border-border px-2.5 py-0.5 text-xs no-underline hover:bg-bg-subtle"
            style="color: var(--color-text-muted)"
          >
            #{tag}
          </a>
        ))}
      </div>
      {seriesPosts.length > 0 && post.data.series && (
        <SeriesNav posts={seriesPosts} current={post} seriesName={post.data.series.name} />
      )}
    </header>

    <div class="prose">
      <Content />
    </div>
  </article>

  {related.length > 0 && (
    <section class="mt-16 border-t border-border pt-8">
      <h2 class="text-lg font-semibold">Related posts</h2>
      <ul class="mt-4 space-y-3">
        {related.map((p) => (
          <li>
            <a href={getPostURL(p)} class="no-underline hover:underline" style="color: var(--color-text)">
              {p.data.title}
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <Comments />
</Layout>
