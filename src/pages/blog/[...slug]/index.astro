---
import { type CollectionEntry, render } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import FormattedDate from '@/components/FormattedDate.astro';
import { getPublishedPosts, getReadingTime, getPostURL } from '@/lib/posts';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\/index$/, '') },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await render(post);
const minutes = getReadingTime(post.body ?? '');

// Related posts: same tag, exclude self, take a handful.
const all = await getPublishedPosts();
const related = all
  .filter((p) => p.id !== post.id && p.data.tags.some((t) => post.data.tags.includes(t)))
  .slice(0, 3);

const description = post.data.description;
---

<Layout title={post.data.title} description={description} canonicalURL={post.data.canonicalURL}>
  <article class="space-y-6">
    <header class="space-y-3">
      <h1 class="text-3xl font-bold leading-tight tracking-tight md:text-4xl">{post.data.title}</h1>
      <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm" style="color: var(--color-text-muted)">
        <FormattedDate date={post.data.pubDatetime} />
        <span aria-hidden="true">·</span>
        <span>{minutes} min read</span>
        {post.data.modDatetime && (
          <>
            <span aria-hidden="true">·</span>
            <span>updated <FormattedDate date={post.data.modDatetime} /></span>
          </>
        )}
      </div>
      <div class="flex flex-wrap gap-2">
        {post.data.tags.map((tag) => (
          <a
            href={`/tags/${tag}`}
            class="rounded-full border border-border px-2 py-0.5 text-xs no-underline hover:bg-bg-subtle"
            style="color: var(--color-text-muted)"
          >
            #{tag}
          </a>
        ))}
      </div>
    </header>

    <div class="prose">
      <Content />
    </div>
  </article>

  {related.length > 0 && (
    <section class="mt-16 border-t border-border pt-8">
      <h2 class="text-lg font-semibold">Related posts</h2>
      <ul class="mt-4 space-y-3">
        {related.map((p) => (
          <li>
            <a href={getPostURL(p)} class="no-underline hover:underline" style="color: var(--color-text)">
              {p.data.title}
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}
</Layout>
