---
import Layout from '@/layouts/Layout.astro';
import PostCard from '@/components/PostCard.astro';
import { getPublishedPosts } from '@/lib/posts';
import { SITE } from '@/config';

const posts = await getPublishedPosts();
const recent = posts.slice(0, SITE.postPerIndex);
---

<Layout>
  <section class="space-y-12">
    <div class="space-y-3">
      <h1 class="text-4xl font-bold tracking-tight">{SITE.title}</h1>
      <p class="text-lg" style="color: var(--color-text-muted)">{SITE.desc}</p>
    </div>

    <div class="space-y-10">
      {recent.map((post) => <PostCard post={post} />)}
    </div>

    {posts.length > recent.length && (
      <p>
        <a href="/blog" class="font-medium">View all posts →</a>
      </p>
    )}
  </section>
</Layout>
