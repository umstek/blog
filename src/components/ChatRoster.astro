---
/**
 * The "info block" shown above a chat conversation: a roster of who's in it.
 * Mirrors the SeriesNav box styling (rounded border + subtle fill) so it reads
 * as metadata, not dialogue. Rendered only when the chat declares participants.
 */
interface Participant {
  name: string;
  role: 'user' | 'assistant' | 'system';
}

interface Props {
  participants: Record<string, Participant>;
}

const { participants } = Astro.props;
const entries = Object.entries(participants);
---

<aside class="mt-12 rounded-lg border border-border bg-bg-subtle p-4">
  <p class="text-xs uppercase tracking-wide" style="color: var(--color-text-muted);">
    Participants
  </p>
  <ul class="mt-2 flex flex-wrap gap-x-4 gap-y-1 text-sm">
    {entries.map(([, p]) => (
      <li class="flex items-center gap-1.5">
        <span class="font-medium" style="color: var(--color-text);">{p.name}</span>
        <span
          class="rounded-sm border border-border px-1 py-0.5 text-[0.65em] uppercase tracking-wide"
          style="color: var(--color-text-muted);"
        >
          {p.role}
        </span>
      </li>
    ))}
  </ul>
</aside>
