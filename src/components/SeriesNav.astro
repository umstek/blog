---
import type { Post } from '@/lib/posts';
import { getPostURL } from '@/lib/posts';

interface Props {
  /** All posts in the current series, in order. */
  posts: Post[];
  /** The post currently being viewed. */
  current: Post;
  seriesName: string;
}

const { posts, current, seriesName } = Astro.props;
const currentIndex = posts.findIndex((p) => p.id === current.id);
---

<nav
  aria-label={`${seriesName} series navigation`}
  class="mt-12 rounded-lg border border-border bg-bg-subtle p-4"
>
  <p class="text-xs uppercase tracking-wide" style="color: var(--color-text-muted)">
    Series · {seriesName}
  </p>
  <ol class="mt-2 space-y-1">
    {posts.map((p, i) => {
      const isCurrent = p.id === current.id;
      return (
        <li class="flex items-baseline gap-2 text-sm">
          <span class="tabular-nums" style="color: var(--color-text-muted)">{i + 1}.</span>
          {isCurrent ? (
            <span class="font-semibold" style="color: var(--color-text)">
              {p.data.title}
            </span>
          ) : (
            <a href={getPostURL(p)} class="no-underline hover:underline">
              {p.data.title}
            </a>
          )}
        </li>
      );
    })}
  </ol>
  {currentIndex >= 0 && (
    <p class="mt-3 text-xs" style="color: var(--color-text-muted)">
      Part {currentIndex + 1} of {posts.length}
    </p>
  )}
</nav>
