---
import { getParticipant } from '@/lib/chat-roster';

/**
 * A single chat turn. Used in chat .mdx bodies:
 *   <Turn speaker="me">...</Turn>
 *
 * `speaker` is a key into the frontmatter `participants` roster, bridged in
 * via src/lib/chat-roster.ts (MDX bodies can't read frontmatter).
 *
 * Visual rules:
 *   - Full-width rounded rectangles — this is a blog, not a messaging app, so
 *     no side alignment and no wasted horizontal space.
 *   - Outline (border) color carries the speaker identity — NO fill. bg is set
 *     to --color-bg purely so the flat corner masks cleanly (reads transparent).
 *   - Colors: Me (user) uses the site accent/link color (--color-accent); the
 *     AI (assistant) stays neutral gray (--color-text-muted). The name label
 *     uses the same color as the border.
 *   - The "speech bubble" shape comes from which corner is NOT rounded: user
 *     leaves the BOTTOM-RIGHT corner flat, assistant leaves the BOTTOM-LEFT
 *     corner flat — the flat corner points toward the label below it.
 *   - Speaker name + role chip sit BELOW the bubble, hugging the flat corner
 *     (user = bottom-right, assistant = bottom-left).
 */
interface Props {
  /** Key into the participants roster (e.g. "me", "gpt"). */
  speaker: string;
}

const { speaker } = Astro.props;
const participant = getParticipant(speaker);
const name = participant?.name ?? speaker;
const role = participant?.role ?? 'assistant';
// user = the human = flat corner on the right; assistant = flat on the left.
const side = role === 'user' ? 'right' : 'left';
// Outline + label color: accent for the human, muted gray for the AI.
const accent = role === 'user' ? 'var(--color-accent)' : 'var(--color-text-muted)';
---

<figure class="chat-turn">
  <div class="chat-bubble" data-side={side} style={`border-color: ${accent};`}>
    <slot />
  </div>
  <figcaption class="chat-label" data-side={side} style={`color: ${accent};`}>
    <span class="chat-name">{name}</span>
    <span class="chat-role">{role}</span>
  </figcaption>
</figure>

<style>
  .chat-turn {
    margin: 1.75rem 0;
    /* Full width — a blog, not a chat app. No side alignment. */
  }

  /* Outline-only rounded rectangle. bg = page token so the flat corner masks
     cleanly; visually transparent (no fill). border-color is set inline per
     speaker; one corner is flattened to give the speech-bubble "point". */
  .chat-bubble {
    border: 1px solid var(--color-border);
    border-radius: 1.25rem;
    background: var(--color-bg);
    padding: 0.9rem 1.25rem;
  }
  /* User: bottom-right flat. Assistant: bottom-left flat. */
  .chat-bubble[data-side='right'] {
    border-bottom-right-radius: 0;
  }
  .chat-bubble[data-side='left'] {
    border-bottom-left-radius: 0;
  }
  /* Tighten prose margins at the bubble's edges so content sits flush inside. */
  .chat-bubble > :first-child {
    margin-top: 0;
  }
  .chat-bubble > :last-child {
    margin-bottom: 0;
  }

  /* Speaker label, BELOW the bubble, hugging the flat-corner side. Color is
     set inline per speaker (matches the border). */
  .chat-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0.4rem 0.4rem 0;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .chat-label[data-side='right'] {
    justify-content: flex-end;
  }
  .chat-label[data-side='left'] {
    justify-content: flex-start;
  }
  .chat-role {
    border: 1px solid currentColor;
    border-radius: 0.1875rem;
    padding: 0.06em 0.4em;
    font-size: 0.65em;
    text-transform: uppercase;
    opacity: 0.85;
  }
</style>
