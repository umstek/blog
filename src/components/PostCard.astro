---
import type { Post } from '@/lib/posts';
import { getPostURL, getReadingTime } from '@/lib/posts';
import FormattedDate from './FormattedDate.astro';

interface Props {
  post: Post;
}

const { post } = Astro.props;
const url = getPostURL(post);
// Render() returns the raw markdown body; cheap enough for a word count.
const minutes = getReadingTime(post.body ?? '');
---

<article class="group">
  <h2 class="text-lg font-semibold leading-snug">
    <a href={url} class="no-underline hover:underline" style="color: var(--color-text)">
      {post.data.title}
    </a>
  </h2>
  <div class="mt-1 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm" style="color: var(--color-text-muted)">
    <FormattedDate date={post.data.pubDatetime} />
    <span aria-hidden="true">·</span>
    <span>{minutes} min read</span>
  </div>
  <p class="mt-2 line-clamp-2" style="color: var(--color-text-muted)">
    {post.data.description}
  </p>
  <div class="mt-2 flex flex-wrap gap-2">
    {post.data.tags.map((tag) => (
      <a
        href={`/tags/${tag}`}
        class="rounded-full border border-border px-2 py-0.5 text-xs no-underline hover:bg-bg-subtle"
        style="color: var(--color-text-muted)"
      >
        #{tag}
      </a>
    ))}
  </div>
</article>
